        {
            "type": "LoggerComponent",
            "name": "Logger"
        },
        {
            "type": "Config",
            "name": "Config"
        },
        {
            "type": "ConsoleVariable",
            "name": "ConsoleVariable"
        },
        {
            "type": "ThreadPoolComponent",
            "name": "ThreadPool"
        },
        {
            "type": "Keystore",
            "name": "Keystore",
